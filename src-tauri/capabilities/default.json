{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "$DOWNLOAD" }, { "path": "$DOWNLOAD/**" }, { "path": "$DOCUMENT/**" }, { "path": "$AUDIO/**" }, { "path": "$VIDEO/**" }, { "path": "$DESKTOP/**" }]
    },
    "dialog:default",
    "updater:default",
    "process:allow-restart"
  ]
}
